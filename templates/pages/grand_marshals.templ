templ GrandMarshals() {
	@layouts.Base(meta.New("Grand Marshals", "Celebrating the Nabor Days Grand Marshals — Cadott neighbors honored for service, stories, and community spirit.").WithCanonical("https://www.cadottcommunity.com/grand-marshals").WithOGImageInfo("/static/images/nabor-days-2025/grand-marshals-2025-alborado.jpg", "Anson and Donna Alborado, the 2025 Cadott Nabor Days Grand Marshals", 1200, 630), "Grand Marshals") {
		<!-- JSON-LD Breadcrumb -->
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "BreadcrumbList",
			"itemListElement": [
				{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.cadottcommunity.com/"},
				{"@type": "ListItem", "position": 2, "name": "Events", "item": "https://www.cadottcommunity.com/events"},
				{"@type": "ListItem", "position": 3, "name": "Grand Marshals", "item": "https://www.cadottcommunity.com/grand-marshals"}
			]
		}
		</script>
		<!-- ══════ HERO ══════ -->
		<section class="bg-cca-gold-500 px-4 py-14 sm:py-20">
			<div class="mx-auto max-w-6xl">
				<p class="text-xs font-bold uppercase tracking-[0.2em] text-white/80">👑 Nabor Days Honor</p>
				<h1 class="mt-3 font-display text-4xl font-bold leading-[1.1] text-white sm:text-5xl">Our Grand Marshals</h1>
				<p class="mt-4 max-w-xl text-lg text-white/80">Every Nabor Days parade is led by a Grand Marshal — a Cadott neighbor recognized for service, stories, and community spirit.</p>
			</div>
		</section>
		<!-- ══════ NOMINATE ══════ -->
		<section class="px-4 py-14">
			<div class="mx-auto max-w-4xl">
				<div class="grid gap-8 lg:grid-cols-[1fr_320px] lg:items-center">
					<div class="space-y-4">
						<p class="section-label">Nominations</p>
						<h2 class="font-display text-2xl font-bold text-cca-ink">Know someone who should lead the parade?</h2>
						<p class="text-cca-body">Grand Marshal nominations are collected from <strong>May 1st to May 31st</strong> every year. For more information or to nominate someone, please reach out to <strong>Ashley Anderson</strong> at <a href="mailto:cadottchirodc@gmail.com" class="text-cca-teal-600 underline decoration-cca-teal-600/30 hover:decoration-cca-teal-600 transition">cadottchirodc@gmail.com</a>.</p>
						<div class="flex flex-wrap gap-3 pt-2">
							@components.ButtonPrimary("mailto:cadottchirodc@gmail.com?subject=Grand%20Marshal%20Nomination", "Email Ashley")
							@components.ButtonGhost("/events/nabor-days", "Back to Nabor Days")
						</div>
					</div>
					<figure class="overflow-hidden rounded-xl shadow-lg">
						<img class="h-72 w-full object-cover" src="/static/images/nabor-days-2025/grand-marshals-2025-alborado.jpg" alt="Anson and Donna Alborado, the 2025 Cadott Nabor Days Grand Marshals, holding their plaque" loading="lazy"/>
						<figcaption class="bg-cca-ink px-4 py-3 text-sm text-white/80">2025 Grand Marshals · Anson &amp; Donna Alborado</figcaption>
					</figure>
				</div>
			</div>
		</section>
		<!-- ══════ HISTORY ══════ -->
		<section class="bg-cca-wash px-4 py-14">
			<div class="mx-auto max-w-4xl space-y-6">
				<div>
					<p class="section-label">History</p>
					<h2 class="mt-2 font-display text-2xl font-bold text-cca-ink">Past Grand Marshals</h2>
					<p class="mt-2 text-cca-muted">A roll call of the neighbors who've led the Nabor Days parade since 1970.</p>
				</div>
				<div class="overflow-hidden rounded-xl border border-cca-line bg-white shadow-sm">
					<dl class="divide-y divide-cca-line">
						for _, entry := range GrandMarshalHistory {
							<div class="grid grid-cols-[80px_1fr] gap-4 px-5 py-3 text-sm sm:grid-cols-[100px_1fr]">
								<dt class="font-display font-bold text-cca-gold-600">{ entry.Year }</dt>
								<dd class="text-cca-body">{ entry.Name }</dd>
							</div>
						}
					</dl>
				</div>
				<p class="text-xs text-cca-muted">Spot a name that's missing or wrong? <a href="mailto:cadott-community@googlegroups.com" class="text-cca-teal-600 underline decoration-cca-teal-600/30 hover:decoration-cca-teal-600 transition">Let us know</a> and we'll fix it.</p>
			</div>
		</section>
	}
}
