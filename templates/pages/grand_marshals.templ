package pages

import (
	"ccassociation/internal/meta"
	"ccassociation/templates/components"
	"ccassociation/templates/layouts"
)

type GrandMarshalEntry struct {
	Year string
	Name string
}

var GrandMarshalHistory = []GrandMarshalEntry{
	{"2025", "Anson & Donna Alborado"},
	{"2024", "Gary & Donna Rykal"},
	{"2023", "Cedric Boettcher"},
	{"2022", "Eugene & Ann Bell"},
