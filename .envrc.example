# Copy this file to .envrc and edit with your values
# Then run: direnv allow

# Database (SQLite)
export DATABASE_URL="./data/ccassociation.db"

# Server
export PORT="8000"
export ENV="development"
export LOG_LEVEL="DEBUG"

# Site / SEO
export SITE_NAME="Cadott Community Association"
# SITE_URL is the public origin, used to make og:image and twitter:image
# absolute. In production set this to the live domain (e.g.
# https://cadottcommunity.dokploy.digitaldrywood.com). Without it, social
# previews on Facebook/LinkedIn/Twitter will fail to load.
export SITE_URL="http://localhost:8000"
export DEFAULT_OG_IMAGE="/static/images/og-default.png"
